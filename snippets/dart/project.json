{
  "Formz Input": {
    "prefix": "fzinput",
    "body": [
      "import 'package:formz/formz.dart';",
      "",
      "enum ${1:Input}ValidationError { empty }",
      "",
      "class ${1:Input} extends FormzInput<String, ${1:Input}ValidationError> {",
      "  const ${1:Input}.pure([super.value = '']) : super.pure();",
      "  const ${1:Input}.dirty([super.value = '']) : super.dirty();",
      "",
      "  @override",
      "${1:Input}ValidationError? validator(String value) {",
      "    if (value.isEmpty) return ${1:Input}ValidationError.empty;",
      "",
      "    return null;$0",
      "  }",
      "}"
    ],
    "description": "Creates a FormzInput class"
  },
  "Drift Provider": {
    "prefix": "dpro",
    "body": [
      "class ${1:Model}Provider {",
      "  ${1:Model}Provider({",
      "    required AppDatabase db,",
      "  }) : _db = db;",
      "",
      "  final AppDatabase _db;",
      "",
      "  Future<void> create${1:Model}(${1:Model}sCompanion ${1/(.*)/${1:/camelcase}/}) async {",
      "    await _db.into(_db.${1/(.*)/${1:/camelcase}/}s).insert(${1/(.*)/${1:/camelcase}/});",
      "  }",
      "",
      "  Future<void> create${1:Model}s(List<${1:Model}sCompanion> ${1/(.*)/${1:/camelcase}/}s) async {",
      "    await _db.batch((batch) {",
      "      batch.insertAll(",
      "        _db.${1/(.*)/${1:/camelcase}/}s,",
      "        ${1/(.*)/${1:/camelcase}/}s,",
      "      );",
      "    });",
      "  }",
      "",
      "  Future<void> update${1:Model}(${1:Model}sCompanion ${1/(.*)/${1:/camelcase}/}) async {",
      "    await _db.update(_db.${1/(.*)/${1:/camelcase}/}s).replace(",
      "          ${1/(.*)/${1:/camelcase}/}.copyWith(",
      "            updatedAt: Value(DateTime.now().toUtc()),",
      "          ),",
      "        );",
      "  }",
      "",
      "  Future<void> delete${1:Model}(int id) async {",
      "    await (_db.delete(_db.${1/(.*)/${1:/camelcase}/}s)",
      "          ..where(",
      "            (b) => b.id.equals(id),",
      "          ))",
      "        .go();",
      "  }",
      "",
      "  Future<List<${1:Model}>> getAll${1:Model}s() async {",
      "    return (_db.select(_db.${1/(.*)/${1:/camelcase}/}s)",
      "          ..where(",
      "            (b) => b.deletedAt.isNull(),",
      "          ))",
      "        .get();",
      "  }",
      "",
      "  Stream<List<${1:Model}>> get${1:Model}sStream({",
      "    String? search,",
      "    int page = 1,",
      "    int pageSize = 15,",
      "    String sortColumn = 'name',",
      "    bool isSortAscending = true,",
      "  }) {",
      "    final sortColumnObj = _db.${1/(.*)/${1:/camelcase}/}s.\\$columns.firstWhereOrNull(",
      "      (element) {",
      "        return element.name == sortColumn;",
      "      },",
      "    );",
      "",
      "    final statement = (_db.select(_db.${1/(.*)/${1:/camelcase}/}s)",
      "      ..where(",
      "        (b) => Expression.and([",
      "          b.deletedAt.isNull(),",
      "          if (search != null) b.name.like('%\\$search%'),",
      "        ]),",
      "      )",
      "      ..limit(",
      "        pageSize,",
      "        offset: (page - 1) * pageSize,",
      "      ));",
      "",
      "    if (sortColumnObj != null) {",
      "      statement.orderBy([",
      "        (_) {",
      "          return OrderingTerm(",
      "            expression: sortColumnObj,",
      "            mode: isSortAscending ? OrderingMode.asc : OrderingMode.desc,",
      "          );",
      "        }",
      "      ]);",
      "    }",
      "",
      "    return statement.watch();",
      "  }",
      "",
      "  Stream<int> getTotalActiveRecords({",
      "    String? search,",
      "  }) {",
      "    return _db.${1/(.*)/${1:/camelcase}/}s.count(where: (row) {",
      "      return Expression.and([",
      "        row.deletedAt.isNull(),",
      "        if (search != null) row.name.like('%\\$search%'),",
      "      ]);",
      "    }).watchSingle();",
      "  }",
      "}",
      ""
    ],
    "description": "A drift provider class"
  },
  "Drift Repository": {
    "prefix": "drepo",
    "body": [
      "class ${1:Model}Repository {",
      "  ${1:Model}Repository({",
      "    required ${1:Model}Provider ${1/(.*)/${1:/camelcase}/}Provider,",
      "  }) : _${1/(.*)/${1:/camelcase}/}Provider = ${1/(.*)/${1:/camelcase}/}Provider;",
      "",
      "  final ${1:Model}Provider _${1/(.*)/${1:/camelcase}/}Provider;",
      "",
      "  Future<void> create${1:Model}(${1:Model}sCompanion ${1/(.*)/${1:/camelcase}/}) async {",
      "    await _${1/(.*)/${1:/camelcase}/}Provider.create${1:Model}(",
      "      ${1/(.*)/${1:/camelcase}/},",
      "    );",
      "  }",
      "",
      "  Future<void> create${1:Model}s(List<${1:Model}sCompanion> ${1/(.*)/${1:/camelcase}/}s) async {",
      "    await _${1/(.*)/${1:/camelcase}/}Provider.create${1:Model}s(",
      "      ${1/(.*)/${1:/camelcase}/}s,",
      "    );",
      "  }",
      "",
      "  Future<void> update${1:Model}(${1:Model}sCompanion ${1/(.*)/${1:/camelcase}/}) async {",
      "    await _${1/(.*)/${1:/camelcase}/}Provider.update${1:Model}(",
      "      ${1/(.*)/${1:/camelcase}/},",
      "    );",
      "  }",
      "",
      "  Future<void> delete${1:Model}(int id) async {",
      "    await _${1/(.*)/${1:/camelcase}/}Provider.delete${1:Model}(id);",
      "  }",
      "",
      "  Future<List<${1:Model}>> getAll${1:Model}s() async {",
      "    return _${1/(.*)/${1:/camelcase}/}Provider.getAll${1:Model}s();",
      "  }",
      "",
      "  Stream<List<${1:Model}>> get${1:Model}sStream({",
      "    String? search,",
      "    int page = 1,",
      "    int pageSize = 15,",
      "    String sortColumn = 'name',",
      "    bool isSortAscending = true,",
      "  }) {",
      "    return _${1/(.*)/${1:/camelcase}/}Provider.get${1:Model}sStream(",
      "      search: search,",
      "      page: page,",
      "      pageSize: pageSize,",
      "      sortColumn: sortColumn,",
      "      isSortAscending: isSortAscending,",
      "    );",
      "  }",
      "",
      "  Stream<int> getTotalActiveRecords({",
      "    String? search,",
      "  }) {",
      "    return _${1/(.*)/${1:/camelcase}/}Provider.getTotalActiveRecords(",
      "      search: search,",
      "    );",
      "  }",
      "}"
    ],
    "description": "A drift repository class"
  }
}
